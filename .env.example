# Kopieer dit bestand naar `.env` en vul je echte keys in.
# `.env` staat in .gitignore — komt nooit in git.

# Anthropic API key voor de chatbot (begin met sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key voor embeddings (begin met sk-...)
# Verkrijg via: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Supabase project URL (begin met https://...supabase.co)
# Vind 'm in: Supabase dashboard → Project Settings → Data API → Project URL
SUPABASE_URL=https://jouw-project-id.supabase.co

# Supabase service role key (begin met eyJ...)
# Vind 'm in: Supabase dashboard → Project Settings → API → service_role
# WAARSCHUWING: dit is een geheime key. Deel nooit, commit nooit.
SUPABASE_SERVICE_KEY=eyJ...
